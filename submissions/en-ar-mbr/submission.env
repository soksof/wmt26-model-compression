# Per-package overrides for a modelzip submission, sourced by run.sh if a file named
# exactly `submission.env` (no `.example`) sits next to it. Copy this to submission.env
# in a CONTRASTIVE package to enable it; leave it absent for the greedy PRIMARY.
#
# en-ar self-MBR quality contrastive (chrF-consensus of N samples; §5.5 of the paper):
# zero new checkpoints — the en-ar PRIMARY (vocaball-int4) checkpoint, MBR decode on.
export MODELZIP_MBR=16
# The rest already default to these inside inference.py; uncomment only to override:
# export MODELZIP_MBR_MINP=0.02   # min_p tail-prune (~epsilon sampling)
# export MODELZIP_MBR_TEMP=1.0    # sampling temperature
# export MODELZIP_MBR_SEED=0      # reproducible candidate set
